#!/usr/bin/env python3

from __future__ import annotations

import re
import sys
from pathlib import Path
from tomllib import load

AIRFLOW_DEPENDENCY_RE = re.compile(r"^apache-airflow(?:\[.*])?==(.+)$")


def main() -> int:
    pyproject_path = Path(__file__).resolve().parents[1] / "pyproject.toml"
    with pyproject_path.open("rb") as f:
        pyproject = load(f)

    runtime_deps = pyproject.get("dependency-groups", {}).get("runtime", [])
    airflow_deps = [dep for dep in runtime_deps if dep.startswith("apache-airflow")]

    if len(airflow_deps) != 1:
        print(
            f"expected exactly one apache-airflow dependency in {pyproject_path}, "
            f"found {len(airflow_deps)}",
            file=sys.stderr,
        )
        return 1

    airflow_dependency_match = AIRFLOW_DEPENDENCY_RE.fullmatch(airflow_deps[0])
    if airflow_dependency_match is None:
        print(
            f"apache-airflow dependency must be exactly pinned in {pyproject_path}: {airflow_deps[0]}",
            file=sys.stderr,
        )
        return 1

    print(airflow_dependency_match.group(1))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
